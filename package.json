{
  "name": "task-logger",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build:frontend": "npm --prefix frontend run build",
    "dev:frontend": "npm --prefix frontend run dev",
    "deploy": "npm run build:frontend && npx wrangler deploy",
    "db:execute:local": "npx wrangler d1 execute task-logger-db --local --file=./schema.sql",
    "db:execute:remote": "npx wrangler d1 execute task-logger-db --file=./schema.sql"
  },
  "devDependencies": {
    "wrangler": "^4.105.0"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "jose": "^6.2.3"
  }
}
